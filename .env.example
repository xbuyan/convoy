# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Postgres connection
DATABASE_URL=postgres://convoy:changeme@localhost:5433/convoy?sslmode=disable

# API server
API_PORT=8080

# Comma-separated API keys allowed to submit jobs (placeholder for now —
# we'll replace this with a proper hashed-key store in the security lesson)
API_KEYS=changeme-local-dev-key
